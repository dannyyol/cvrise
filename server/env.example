SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=cvrise
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
