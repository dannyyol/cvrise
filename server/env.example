# --- MySQL (db container) ---
MYSQL_ROOT_PASSWORD=cvrise
MYSQL_DATABASE=cvrise
MYSQL_USER=cvrise
MYSQL_PASSWORD=cvrise

# --- Server common ---
APP_NAME=CVRise
APP_VERSION=0.1.0
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000
DATABASE_URL=mysql+aiomysql://cvrise:cvrise@db:3306/cvrise

DEBUG=True
CLIENT_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://client-dev:3000"]
PDF_CLIENT_BASE_URL=http://client-dev:3000

# --- Server secrets ---
GOOGLE_CLIENT_ID=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30
VERIFY_TOKEN_EXPIRE_HOURS=24
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_OPENAI_API_KEY=

# --- Email ---
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=cvrise
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
