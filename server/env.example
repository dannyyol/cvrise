APP_NAME=cvrise
APP_VERSION=0.1.0
API_PREFIX=/api

HOST=127.0.0.1
PORT=8000

DEBUG=True

CORS_ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
CLIENT_BASE_URL=http://127.0.0.1:3000
PDF_CLIENT_BASE_URL=
